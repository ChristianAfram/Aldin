# Neon PostgreSQL (https://neon.tech) – erforderlich (Laufzeit + Seed)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="dein-geheimes-jwt-secret-hier"

# WhatsApp Nummer (Format: 4915712345678 – ohne + und ohne fuehrende 0)
NEXT_PUBLIC_WA_NUMBER="4915712345678"

# Oeffentliche Basis-URL der Website (optional, Standard: https://aldinb.de)
NEXT_PUBLIC_SITE_URL="https://aldinb.de"

# Admin-Login – wird NUR vom Seed-Script (npm run seed) gelesen.
# Der Login prueft gegen den bcrypt-Hash in der Datenbank, nicht gegen diese Werte.
ADMIN_EMAIL="aldin@example.com"
ADMIN_PASSWORD="sicheres-passwort"
